# ─────────────────────────────────────────────────────────────────────────────
# MomentSearch configuration. Copy to `.env` and edit.
# ─────────────────────────────────────────────────────────────────────────────

# ── Vector database (Qdrant) ────────────────────────────────────────────────
# When running via docker-compose, the backend reaches Qdrant at the service
# name. For a locally-run backend, use http://localhost:6333.
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=moments

# ── Bring Your Own LLM ───────────────────────────────────────────────────────
# MomentSearch only calls an LLM to *synthesize the final cited answer* from the
# frames it already retrieved. Retrieval itself is local (CLIP) and needs no key.
#
# The default provider speaks the OpenAI Chat Completions API, which means it
# also works with any OpenAI-compatible server: Ollama, vLLM, LM Studio,
# Together, Groq, OpenRouter, etc. — just point LLM_BASE_URL at it.
#
# LLM_PROVIDER: "openai" (OpenAI-compatible) | "nvidia" | "anthropic"
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-key-here
# Optional. Leave blank for api.openai.com. Ignored for nvidia (endpoint is
# pre-filled). For local / hosted OpenAI-compatible servers, e.g.:
#   Ollama        -> http://localhost:11434/v1
#   vLLM/LMStudio -> http://localhost:8000/v1
LLM_BASE_URL=
# Must be a VISION-capable model (it is shown the actual video frames).
#   OpenAI    -> gpt-4o-mini, gpt-4o
#   NVIDIA    -> meta/llama-3.2-90b-vision-instruct, meta/llama-3.2-11b-vision-instruct
#   Anthropic -> claude-sonnet-4-6, claude-opus-4-8
#   Ollama    -> llava, llama3.2-vision, qwen2.5-vl
LLM_MODEL=gpt-4o-mini

# ── Visual ingestion ─────────────────────────────────────────────────────────
# How frames are sampled from each video. MomentSearch understands the *visual*
# content of videos — it never transcribes audio.
# FRAME_STRATEGY: "interval" (one frame every N seconds) | "scene" (on scene cuts)
FRAME_STRATEGY=interval
FRAME_INTERVAL_SEC=2
# Scene-cut sensitivity (0-1) when FRAME_STRATEGY=scene; lower = more frames.
SCENE_THRESHOLD=0.4
# Cap frames per video to bound cost/time (0 = no cap).
MAX_FRAMES=400

# CLIP model used for visual + text embeddings (runs locally on CPU or GPU).
CLIP_MODEL=clip-ViT-B-32

# Number of frames retrieved per question and shown as citations.
TOP_K=6
